# --- LCC Hub Environment Configuration ---

# 1. Auth & Session (CRITICAL)
# 32-byte hex string for cookie encryption. Generate with: openssl rand -hex 32
SESSION_SECRET=
ADMIN_SECRET=
CRON_SECRET=

# 2. Firebase (Public/Client)
# Get these from your Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# 3. Firebase Admin (Server-side)
# Get these from your Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Optional: Alternatively provide the whole JSON string
# FIREBASE_SERVICE_ACCOUNT_JSON=

# 4. AI & LLM Core (CRITICAL)
# Get your Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=
# Secondary model for specific tasks
GIT_MODEL_TOKEN=

# 5. Cloudflare Workers AI (For Visualizations)
# Get your Account ID and API Token from Cloudflare Dashboard
ACCOUNT_ID=
AI_WORKER_API=

# 6. Realtime & Notifications (CRITICAL)
# Get your API key from https://ably.com/
ABLY_API_KEY=

# 7. Database (Relational - Turso/LibSQL)
# Get these from your Turso Dashboard
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# 8. Speech & Audio (Deepgram)
# Get these from https://console.deepgram.com/
DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

# 9. Image Hosting (Cloudinary)
# Get these from your Cloudinary Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 10. Email (Nodemailer)
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# 11. Vercel Sandbox (For Python Execution)
# Get these from your Vercel Project Settings (requires Vercel Sandbox setup)
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# 12. External Search
YOUTUBE_API_KEY=
LANGSEARCH_API_KEY=
HUGGINGFACE_API_KEY=
